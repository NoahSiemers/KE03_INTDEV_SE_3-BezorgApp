<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KE03_INTDEV_SE_3.Pages.SickReportPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Ziekmelden"
    BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Frame
                    WidthRequest="46"
                    HeightRequest="46"
                    CornerRadius="17"
                    BackgroundColor="#15191C"
                    Padding="0"
                    HasShadow="False">

                    <Label
                        Text="&#xf0fa;"
                        FontFamily="FontAwesome"
                        FontSize="18"
                        TextColor="#DC2626"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Frame>

                <VerticalStackLayout Grid.Column="1" Spacing="3">
                    <Label
                        Text="Ziekmelden"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="#111827" />

                    <Label
                        Text="Controleer eerst de impact op je dienst en route"
                        FontSize="14"
                        TextColor="#6B7280" />
                </VerticalStackLayout>
            </Grid>

            <!-- Status / deadline card -->
            <Frame
                x:Name="DeadlineStatusFrame"
                CornerRadius="24"
                BackgroundColor="#FFFBEB"
                BorderColor="#FDE68A"
                HasShadow="True"
                Padding="18">

                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            x:Name="DeadlineStatusTitleLabel"
                            Text="3-uursregel controleren"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#92400E" />

                        <Frame
                            Grid.Column="1"
                            x:Name="DeadlineBadgeFrame"
                            BackgroundColor="#FEF3C7"
                            BorderColor="#FDE68A"
                            CornerRadius="14"
                            Padding="10,5"
                            HasShadow="False">

                            <Label
                                x:Name="DeadlineBadgeLabel"
                                Text="Check"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#92400E" />
                        </Frame>
                    </Grid>

                    <Label
                        x:Name="RuleDescriptionLabel"
                        Text="Je kunt je via de app ziekmelden tot 3 uur vóór je dienst begint."
                        FontSize="14"
                        TextColor="#78350F"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <!-- Shift card -->
            <Frame
                CornerRadius="24"
                BackgroundColor="White"
                BorderColor="#E5E7EB"
                HasShadow="True"
                Padding="18">

                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="3">
                            <Label
                                Text="Dienstgegevens"
                                FontSize="21"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Label
                                Text="De planning waarop je ziekmelding invloed heeft"
                                FontSize="13"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Column="1"
                            Text="&#xf073;"
                            FontFamily="FontAwesome"
                            FontSize="19"
                            TextColor="#2D7DF6"
                            VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E5E7EB" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="13">
                        <Label
                            Grid.Row="0"
                            Text="&#xf017;"
                            FontFamily="FontAwesome"
                            FontSize="17"
                            TextColor="#2D7DF6"
                            VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                            <Label Text="Diensttijd" FontSize="12" TextColor="#6B7280" />
                            <Label
                                x:Name="ShiftTimeLabel"
                                Text="Dienst laden..."
                                FontSize="17"
                                FontAttributes="Bold"
                                TextColor="#111827" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Row="1"
                            Text="&#xf0d1;"
                            FontFamily="FontAwesome"
                            FontSize="17"
                            TextColor="#2D7DF6"
                            VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                            <Label Text="Route en bus" FontSize="12" TextColor="#6B7280" />
                            <Label
                                x:Name="RouteLabel"
                                Text="Route laden..."
                                FontSize="17"
                                FontAttributes="Bold"
                                TextColor="#111827" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Row="2"
                            Text="&#xf54e;"
                            FontFamily="FontAwesome"
                            FontSize="17"
                            TextColor="#2D7DF6"
                            VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="2">
                            <Label Text="Depot" FontSize="12" TextColor="#6B7280" />
                            <Label
                                x:Name="DepotLabel"
                                Text="Depot laden..."
                                FontSize="17"
                                FontAttributes="Bold"
                                TextColor="#111827" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Route impact -->
            <Frame
                CornerRadius="24"
                BackgroundColor="White"
                BorderColor="#E5E7EB"
                HasShadow="True"
                Padding="18">

                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="3">
                            <Label
                                Text="Route-impact"
                                FontSize="21"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Label
                                Text="Wat moet de planner opnieuw verdelen?"
                                FontSize="13"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>

                        <Frame
                            x:Name="ImpactBadgeFrame"
                            Grid.Column="1"
                            BackgroundColor="#F9FAFB"
                            BorderColor="#E5E7EB"
                            CornerRadius="14"
                            Padding="10,6"
                            HasShadow="False">

                            <Label
                                x:Name="ImpactBadgeLabel"
                                Text="Geen route"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#6B7280" />
                        </Frame>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Frame
                            CornerRadius="18"
                            BackgroundColor="#F9FAFB"
                            BorderColor="#E5E7EB"
                            Padding="14"
                            HasShadow="False">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Totaal" FontSize="12" TextColor="#6B7280" />
                                <Label
                                    x:Name="TotalPackagesLabel"
                                    Text="0"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />
                            </VerticalStackLayout>
                        </Frame>

                        <Frame
                            Grid.Column="1"
                            CornerRadius="18"
                            BackgroundColor="#FFF7ED"
                            BorderColor="#FED7AA"
                            Padding="14"
                            HasShadow="False">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Openstaand" FontSize="12" TextColor="#C2410C" />
                                <Label
                                    x:Name="OpenPackagesLabel"
                                    Text="0"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    TextColor="#C2410C" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <Frame
                        CornerRadius="18"
                        BackgroundColor="#F9FAFB"
                        BorderColor="#E5E7EB"
                        Padding="14"
                        HasShadow="False">

                        <Label
                            x:Name="RouteImpactDescriptionLabel"
                            Text="Zodra er een dienst is gekoppeld, toont de app de impact op de route."
                            FontSize="14"
                            TextColor="#374151"
                            LineBreakMode="WordWrap" />
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- Privacy / data minimisation -->
            <Frame
                CornerRadius="20"
                BackgroundColor="#EFF6FF"
                BorderColor="#BFDBFE"
                HasShadow="False"
                Padding="16">

                <VerticalStackLayout Spacing="7">
                    <Label
                        Text="Privacybewuste melding"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#1D4ED8" />

                    <Label
                        Text="Vul alleen informatie in die nodig is voor planning. Medische details zijn niet nodig; de planner moet vooral weten of de route opnieuw verdeeld moet worden."
                        FontSize="14"
                        TextColor="#1E3A8A"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <!-- No shift panel -->
            <Frame
                x:Name="NoShiftPanel"
                IsVisible="False"
                CornerRadius="24"
                BackgroundColor="White"
                BorderColor="#E5E7EB"
                HasShadow="True"
                Padding="18">

                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Geen dienst gevonden"
                        FontSize="21"
                        FontAttributes="Bold"
                        TextColor="#111827" />

                    <Label
                        Text="Er staat vandaag geen dienst voor je ingepland. Een ziekmelding via de app is daarom niet nodig."
                        FontSize="14"
                        TextColor="#6B7280"
                        LineBreakMode="WordWrap" />

                    <Button
                        Text="Terug naar dienstcentrum"
                        HeightRequest="52"
                        BackgroundColor="#2D7DF6"
                        TextColor="White"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        Clicked="OnBackClicked" />
                </VerticalStackLayout>
            </Frame>

            <!-- Form panel -->
            <Frame
                x:Name="SickReportFormPanel"
                IsVisible="False"
                CornerRadius="24"
                BackgroundColor="White"
                BorderColor="#E5E7EB"
                HasShadow="True"
                Padding="18">

                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="3">
                            <Label
                                Text="Ziekmelding invullen"
                                FontSize="21"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Label
                                x:Name="FormInstructionLabel"
                                Text="Deze melding wordt gebruikt om de route tijdig opnieuw te plannen."
                                FontSize="13"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Column="1"
                            Text="&#xf303;"
                            FontFamily="FontAwesome"
                            FontSize="18"
                            TextColor="#2D7DF6"
                            VerticalOptions="Center" />
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Reden"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#374151" />

                        <Picker
                            x:Name="ReasonPicker"
                            Title="Kies een reden">
                            <Picker.Items>
                                <x:String>Ziek / medische reden</x:String>
                                <x:String>Ongeval onderweg</x:String>
                                <x:String>Familieomstandigheid</x:String>
                                <x:String>Anders</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label
                                Text="Toelichting"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="#374151" />

                            <Label
                                x:Name="DescriptionCounterLabel"
                                Grid.Column="1"
                                Text="0/160"
                                FontSize="12"
                                TextColor="#6B7280" />
                        </Grid>

                        <Editor
                            x:Name="DescriptionEditor"
                            Placeholder="Bijvoorbeeld: ik kan mijn dienst vandaag niet rijden en blijf bereikbaar voor de planner."
                            PlaceholderColor="#9CA3AF"
                            TextColor="#111827"
                            BackgroundColor="#F9FAFB"
                            AutoSize="TextChanges"
                            HeightRequest="115"
                            MaxLength="160"
                            TextChanged="OnDescriptionChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Verwachte terugkeer"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#374151" />

                        <Picker
                            x:Name="ExpectedReturnPicker"
                            Title="Kies verwachte terugkeer">
                            <Picker.Items>
                                <x:String>Morgen</x:String>
                                <x:String>Overmorgen</x:String>
                                <x:String>Nog onbekend</x:String>
                            </Picker.Items>
                        </Picker>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <CheckBox
                            x:Name="ConfirmationCheckBox"
                            VerticalOptions="Start" />

                        <Label
                            Grid.Column="1"
                            Text="Ik bevestig dat ik mijn melding naar waarheid invul en bereikbaar blijf voor de planner."
                            FontSize="13"
                            TextColor="#374151"
                            LineBreakMode="WordWrap" />
                    </Grid>

                    <Button
                        Text="Ziekmelding versturen"
                        HeightRequest="54"
                        BackgroundColor="#2D7DF6"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        Clicked="OnSubmitClicked" />

                    <Button
                        Text="Annuleren"
                        HeightRequest="52"
                        BackgroundColor="White"
                        TextColor="#111827"
                        BorderColor="#D1D5DB"
                        BorderWidth="1"
                        CornerRadius="14"
                        Clicked="OnBackClicked" />
                </VerticalStackLayout>
            </Frame>

            <!-- Too late panel -->
            <Frame
                x:Name="CallPlannerPanel"
                IsVisible="False"
                CornerRadius="24"
                BackgroundColor="#FEF2F2"
                BorderColor="#FCA5A5"
                HasShadow="True"
                Padding="18">

                <VerticalStackLayout Spacing="14">

                    <Label
                        Text="Appmelding niet meer mogelijk"
                        FontSize="21"
                        FontAttributes="Bold"
                        TextColor="#B42318" />

                    <Label
                        x:Name="CallPlannerReasonLabel"
                        Text="Je dienst begint binnen 3 uur. Bel de planner direct."
                        FontSize="14"
                        TextColor="#374151"
                        LineBreakMode="WordWrap" />

                    <Frame
                        CornerRadius="16"
                        BackgroundColor="White"
                        BorderColor="#FCA5A5"
                        HasShadow="False"
                        Padding="14">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label
                                Text="&#xf095;"
                                FontFamily="FontAwesome"
                                FontSize="18"
                                TextColor="#DC2626"
                                VerticalOptions="Center" />

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Planner" FontSize="12" TextColor="#6B7280" />
                                <Label
                                    x:Name="PlannerPhoneLabel"
                                    Text="06 98765432"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <Button
                        Text="Bel planner"
                        HeightRequest="54"
                        BackgroundColor="#2D7DF6"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        Clicked="OnCallPlannerClicked" />

                    <Button
                        Text="Kopieer telefoonnummer"
                        HeightRequest="52"
                        BackgroundColor="White"
                        TextColor="#111827"
                        BorderColor="#D1D5DB"
                        BorderWidth="1"
                        CornerRadius="14"
                        Clicked="OnCopyPlannerNumberClicked" />

                    <Button
                        Text="Terug naar dienstcentrum"
                        HeightRequest="52"
                        BackgroundColor="White"
                        TextColor="#B42318"
                        BorderColor="#FCA5A5"
                        BorderWidth="1"
                        CornerRadius="14"
                        Clicked="OnBackClicked" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>