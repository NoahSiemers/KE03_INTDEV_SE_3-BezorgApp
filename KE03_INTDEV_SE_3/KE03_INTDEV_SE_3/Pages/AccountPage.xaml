<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KE03_INTDEV_SE_3.Pages.AccountPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Account"
    BackgroundColor="#F3F4F6">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label
            Text="Account &amp; meldingen"
            FontSize="30"
            FontAttributes="Bold"
            TextColor="#111827" />

        <Frame CornerRadius="15" BackgroundColor="White" Padding="18">
            <VerticalStackLayout Spacing="8">
                <Label
                    x:Name="NameLabel"
                    FontSize="22"
                    FontAttributes="Bold" />

                <Label
                    x:Name="EmailLabel"
                    FontSize="15"
                    TextColor="#374151" />

                <Label
                    Text="Meldingen"
                    FontSize="18"
                    FontAttributes="Bold"
                    Margin="0,15,0,0" />

                <Label Text="• Nieuwe ritten worden hier later getoond." />
                <Label Text="• Pakketmeldingen komen hier later te staan." />
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>