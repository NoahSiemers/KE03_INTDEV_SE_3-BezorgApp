<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KE03_INTDEV_SE_3.Pages.TodayRidePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F3F4F6"
    Title="Vandaag">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid
            Grid.Row="0"
            BackgroundColor="#15191C"
            Padding="20,45,20,22"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12">

            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Planning vandaag"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Label
                    x:Name="DateLabel"
                    FontSize="14"
                    TextColor="#D1D5DB" />
            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Column="1"
                Spacing="6"
                HorizontalOptions="End"
                VerticalOptions="Center">

                <Frame
                    x:Name="FlowStepBadgeFrame"
                    CornerRadius="16"
                    BackgroundColor="#2D7DF6"
                    Padding="12,6"
                    HasShadow="False">

                    <Label
                        x:Name="FlowStepBadgeLabel"
                        Text="Stap 1/6"
                        FontSize="12"
                        FontAttributes="Bold"
                        TextColor="White" />
                </Frame>

                <Label
                    x:Name="RouteTimerLabel"
                    Text="Nog niet gestart"
                    FontSize="12"
                    TextColor="#D1D5DB"
                    HorizontalTextAlignment="End" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Current step -->
                <Frame
                    CornerRadius="24"
                    BackgroundColor="White"
                    BorderColor="#E5E7EB"
                    HasShadow="True"
                    Padding="18">

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    x:Name="CurrentStepTitleLabel"
                                    Text="Dienst controleren"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />

                                <Label
                                    x:Name="CurrentStepDescriptionLabel"
                                    Text="Controleer eerst of je de juiste dienst, bus en route voor je hebt."
                                    FontSize="14"
                                    TextColor="#6B7280"
                                    LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <Label
                                Grid.Column="1"
                                Text="&#xf0ae;"
                                FontFamily="FontAwesome"
                                FontSize="22"
                                TextColor="#2D7DF6"
                                VerticalOptions="Center" />
                        </Grid>

                        <VerticalStackLayout
                            x:Name="StepIndicatorLayout"
                            Spacing="8" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Ride info -->
                <Frame
                    x:Name="RideInfoFrame"
                    CornerRadius="22"
                    BackgroundColor="White"
                    BorderColor="#E5E7EB"
                    HasShadow="True"
                    Padding="18">

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">

                        <VerticalStackLayout Spacing="8">
                            <Label
                                x:Name="BranchLabel"
                                FontSize="21"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Label
                                x:Name="TimeLabel"
                                FontSize="14"
                                TextColor="#6B7280" />

                            <HorizontalStackLayout Spacing="8">
                                <Label
                                    Text="&#xf0d1;"
                                    FontFamily="FontAwesome"
                                    FontSize="14"
                                    TextColor="#2D7DF6" />

                                <Label
                                    x:Name="BusLabel"
                                    FontSize="14"
                                    TextColor="#374151" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="8">
                                <Label
                                    Text="&#xf3c5;"
                                    FontFamily="FontAwesome"
                                    FontSize="14"
                                    TextColor="#2D7DF6" />

                                <Label
                                    x:Name="RegionLabel"
                                    FontSize="14"
                                    TextColor="#374151" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Frame
                            Grid.Column="1"
                            CornerRadius="18"
                            BackgroundColor="#F3F7FF"
                            BorderColor="#DBEAFE"
                            WidthRequest="115"
                            Padding="12"
                            HasShadow="False">

                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label
                                    Text="Open"
                                    FontSize="11"
                                    TextColor="#6B7280"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    x:Name="RemainingPackagesLabel"
                                    FontSize="30"
                                    FontAttributes="Bold"
                                    TextColor="#111827"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    Text="pakketten"
                                    FontSize="11"
                                    TextColor="#6B7280"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </Frame>

                <!-- Dynamic workflow content -->
                <VerticalStackLayout
                    x:Name="WorkPanelLayout"
                    Spacing="16" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>